# ─────────────────────────────────────────────────────────────
#  .env.example  —  Variables de entorno para docker-compose
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA commitees el .env con credenciales reales al repositorio.
# ─────────────────────────────────────────────────────────────

# Contraseña root de MySQL (usada tanto por MySQL como por los backends)
MYSQL_ROOT_PASSWORD=SuperSecurePassword123!

# Tu usuario de Docker Hub (o cuenta AWS para ECR)
DOCKERHUB_USERNAME=tu_usuario_dockerhub
